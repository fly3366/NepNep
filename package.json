{
  "name": "nepnep",
  "private": true,
  "version": "0.1.0",
  "description": "Real-time speech-to-text and AI translation desktop app powered by Qwen-Omni",
  "license": "MIT",
  "author": {
    "name": "NepNep Contributors"
  },
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist-electron && vue-tsc && vite build && electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "naive-ui": "^2.38.2",
    "vfonts": "^0.0.3",
    "vue": "^3.5.39",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/audioworklet": "^0.0.55",
    "@types/dom-webcodecs": "^0.1.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "icon-gen": "^5.0.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "io.nepnep.desktop",
    "productName": "nepnep",
    "asar": true,
    "copyright": "© 2024-2026 NepNep Contributors",
    "icon": "logo.png",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "./dist",
      "./dist-electron",
      "./package.json",
      "./logo.png"
    ],
    "mac": {
      "artifactName": "${productName}_${version}_${arch}.${ext}",
      "icon": "logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "${productName}_${version}.${ext}",
      "icon": "public/images/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "public/images/logo.ico",
      "uninstallerIcon": "public/images/logo.ico"
    },
    "releaseInfo": {
      "releaseNotes": "ChangeLog"
    },
    "publish": null
  }
}
